---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = posts[0];
const allPosts = posts.slice(1);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Blog - Digital Piggy Bank" description="Tips, guides, and insights about teaching kids financial literacy, managing allowances, and building smart money habits.">
  <section class="blog-hero section">
    <div class="container">
      <h1>Blog</h1>
      <p class="blog-hero__nav"><a href="/blog/tags">Browse by topic &rsaquo;</a></p>
    </div>
  </section>

  {featuredPost && (
    <section class="featured">
      <div class="container">
        <a href={`/blog/${featuredPost.id}`} class="featured__link">
          <div class="featured__image">
            <Image
              src={featuredPost.data.image}
              alt={featuredPost.data.imageAlt}
              widths={[480, 800, 1200]}
              sizes="(max-width: 480px) 100vw, (max-width: 1200px) 100vw, 1200px"
              format="avif"
              quality={70}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="featured__text">
            <p class="featured__date">{formatDate(featuredPost.data.date)}</p>
            <h2>{featuredPost.data.title}</h2>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="all-posts section">
    <div class="container">
      <h2>All Articles</h2>
      <div class="posts-grid">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-card__image">
              <Image
                src={post.data.image}
                alt={post.data.imageAlt}
                widths={[300, 600]}
                sizes="(max-width: 480px) 100vw, 300px"
                format="avif"
                quality={70}
                loading="lazy"
              />
            </div>
            <div class="post-card__text">
              <p class="post-card__date">{formatDate(post.data.date)}</p>
              <h3>{post.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    text-align: center;
    padding: 48px 0 24px;
  }

  .blog-hero h1 {
    font-family: var(--font-display);
  }

  .blog-hero__nav {
    margin-top: 12px;
    font-size: 0.95rem;
  }

  .blog-hero__nav a {
    color: var(--color-magenta);
  }

  /* Featured post */
  .featured {
    margin-bottom: 40px;
  }

  .featured__link {
    display: block;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s;
  }

  .featured__link:hover {
    transform: translateY(-2px);
  }

  .featured__image img {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .featured__text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    color: white;
  }

  .featured__date {
    font-size: 0.85rem;
    opacity: 0.8;
    margin-bottom: 8px;
  }

  .featured__text h2 {
    color: white;
    font-size: 1.75rem;
  }

  /* All posts grid */
  .all-posts h2 {
    margin-bottom: 32px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 24px;
  }

  .post-card {
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid var(--color-border);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .post-card__image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .post-card__text {
    padding: 16px;
  }

  .post-card__date {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-bottom: 8px;
  }

  .post-card__text h3 {
    font-size: 1.1rem;
    line-height: 1.3;
  }

  @media (max-width: 809px) {
    .featured__image img {
      height: 280px;
    }

    .featured__text h2 {
      font-size: 1.4rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .featured__image img {
      height: 200px;
    }
  }
</style>
