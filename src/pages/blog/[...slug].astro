---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const nextPost = allPosts[currentIndex + 1] || null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title={`${post.data.title} - Digital Piggy Bank`} description={post.data.description} image={post.data.image}>
  <article class="blog-post">
    <div class="blog-post__hero">
      <img src={post.data.image} alt={post.data.imageAlt} width="1200" height="600" />
    </div>

    <div class="blog-post__content container">
      <header class="blog-post__header">
        <h1>{post.data.title}</h1>
        <p class="blog-post__date">{formatDate(post.data.date)}</p>
      </header>

      <div class="blog-post__body prose">
        <Content />
      </div>

      {nextPost && (
        <nav class="blog-post__next">
          <a href={`/blog/${nextPost.id}`}>
            {nextPost.data.title} &rsaquo;
          </a>
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post__hero {
    width: 100%;
    max-height: 500px;
    overflow: hidden;
  }

  .blog-post__hero img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }

  .blog-post__content {
    max-width: 780px;
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .blog-post__header {
    margin-bottom: 40px;
  }

  .blog-post__header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-bottom: 12px;
  }

  .blog-post__date {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  /* Prose styles for rendered markdown */
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 16px;
    font-size: 1.05rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }

  .prose :global(ul) {
    list-style-type: disc;
  }

  .prose :global(ol) {
    list-style-type: decimal;
  }

  .prose :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
    color: var(--color-text);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-magenta);
    padding: 16px 24px;
    margin: 24px 0;
    background: #fdf2fd;
    border-radius: 0 8px 8px 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 8px;
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--color-magenta);
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: var(--color-pink);
  }

  /* Next post link */
  .blog-post__next {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    text-align: right;
  }

  .blog-post__next a {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-magenta);
    transition: color 0.2s;
  }

  .blog-post__next a:hover {
    color: var(--color-pink);
  }

  @media (max-width: 809px) {
    .blog-post__hero img {
      height: 300px;
    }

    .blog-post__content {
      padding-top: 32px;
      padding-bottom: 48px;
    }

    .prose :global(h2) {
      font-size: 1.4rem;
    }
  }

  @media (max-width: 480px) {
    .blog-post__hero img {
      height: 200px;
    }
  }
</style>
