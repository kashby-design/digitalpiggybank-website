---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { article, breadcrumbList } from '../../lib/schema';
import AuthorByline from '../../components/AuthorByline.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { TAG_LABELS, type BlogTag } from '../../content.config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const BRAND_SUFFIX = ' | Digital Piggy Bank';
const pageTitle =
  post.data.title.length + BRAND_SUFFIX.length <= 60
    ? `${post.data.title}${BRAND_SUFFIX}`
    : post.data.title;

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const nextPost = allPosts[currentIndex + 1] || null;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const articleSchema = article({
  title: post.data.title,
  description: post.data.description,
  image: post.data.image,
  datePublished: post.data.date,
  dateModified: post.data.updatedDate,
  url: canonicalURL,
  authorName: post.data.author,
});
const breadcrumbSchema = breadcrumbList([
  { name: 'Home', url: new URL('/', Astro.site).toString() },
  { name: 'Blog', url: new URL('/blog', Astro.site).toString() },
  { name: post.data.title, url: canonicalURL },
]);
---

<BaseLayout
  title={pageTitle}
  description={post.data.description}
  image={post.data.image}
  extraSchema={[articleSchema, breadcrumbSchema]}
>
  <article class="blog-post">
    <div class="blog-post__hero">
      <img src={post.data.image} alt={post.data.imageAlt} width="1200" height="600" />
    </div>

    <div class="blog-post__content container">
      <header class="blog-post__header">
        <h1>{post.data.title}</h1>
        <AuthorByline
          author={post.data.author}
          date={post.data.date}
          updatedDate={post.data.updatedDate}
        />
        {(post.data.tags ?? []).length > 0 && (
          <ul class="blog-post__tags">
            {(post.data.tags as BlogTag[]).map((t) => (
              <li><a href={`/blog/tag/${t}`}>#{TAG_LABELS[t]}</a></li>
            ))}
          </ul>
        )}
      </header>

      <div class="blog-post__body prose">
        <Content />
      </div>

      <RelatedPosts currentSlug={post.id} tags={post.data.tags ?? []} />

      {nextPost && (
        <nav class="blog-post__next">
          <a href={`/blog/${nextPost.id}`}>
            {nextPost.data.title} &rsaquo;
          </a>
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post__hero {
    width: 100%;
    max-height: 500px;
    overflow: hidden;
  }

  .blog-post__hero img {
    width: 100%;
    height: 500px;
    object-fit: cover;
  }

  .blog-post__content {
    max-width: 780px;
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .blog-post__header {
    margin-bottom: 40px;
  }

  .blog-post__header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-bottom: 12px;
  }

  .blog-post__tags {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .blog-post__tags a {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--color-border);
    color: var(--color-text);
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .blog-post__tags a:hover {
    background: var(--color-magenta);
    color: var(--color-white);
  }

  /* Prose styles for rendered markdown */
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 16px;
    font-size: 1.05rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }

  .prose :global(ul) {
    list-style-type: disc;
  }

  .prose :global(ol) {
    list-style-type: decimal;
  }

  .prose :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
    color: var(--color-text);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-magenta);
    padding: 16px 24px;
    margin: 24px 0;
    background: #fdf2fd;
    border-radius: 0 8px 8px 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 8px;
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--color-magenta);
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: var(--color-pink);
  }

  /* Next post link */
  .blog-post__next {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    text-align: right;
  }

  .blog-post__next a {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-magenta);
    transition: color 0.2s;
  }

  .blog-post__next a:hover {
    color: var(--color-pink);
  }

  @media (max-width: 809px) {
    .blog-post__hero img {
      height: 300px;
    }

    .blog-post__content {
      padding-top: 32px;
      padding-bottom: 48px;
    }

    .prose :global(h2) {
      font-size: 1.4rem;
    }
  }

  @media (max-width: 480px) {
    .blog-post__hero img {
      height: 200px;
    }
  }
</style>
