---
import AppStoreButtons from './AppStoreButtons.astro';
---

<section id="top" class="hero">
  <div class="hero__inner container">
    <div class="hero__text">
      <div class="hero__titles">
        <h1 class="hero__title">Track Allowances</h1>
        <h1 class="hero__subtitle">without breaking the Bank</h1>
      </div>
      <p class="hero__tagline">For parents of kids too young to have a bank account and who don't have cash lying around to fill a physical piggy bank</p>
      <AppStoreButtons />
    </div>
  </div>
  <video class="hero__video" muted playsinline preload="auto">
    <source src="/images/hero-video.mp4" type="video/mp4" />
  </video>
</section>

<script>
  const video = document.querySelector('.hero__video') as HTMLVideoElement;
  if (video) {
    let lastScrollY = window.scrollY;
    let isInView = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          isInView = entry.isIntersecting;
        });
      },
      { threshold: 0.25 }
    );
    observer.observe(document.querySelector('.hero')!);

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      const scrollingDown = currentScrollY > lastScrollY;
      lastScrollY = currentScrollY;

      if (scrollingDown && isInView && video.paused && !video.ended) {
        video.play();
      }
    }, { passive: true });
  }
</script>

<style>
  .hero {
    background: white;
    padding: 132px 0 80px;
    overflow: hidden;
    position: relative;
    min-height: 56.25vw; /* 16:9 aspect ratio */
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 29px;
    position: relative;
    z-index: 1;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .hero__titles {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero h1 {
    margin: 0;
    line-height: 1;
    color: var(--color-dark);
  }

  .hero__tagline {
    font-size: 1.125rem;
    color: var(--color-dark);
    max-width: 609px;
    line-height: 1.5;
    letter-spacing: 0.005em;
  }

  .hero__video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    z-index: 0;
  }

  /* === On-Load Keyframes === */
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* === On-Load Animations (motion-safe) === */
  @media (prefers-reduced-motion: no-preference) {
    .hero__title {
      animation: hero-fade-up 500ms ease-out both;
      animation-delay: 0ms;
    }

    .hero__subtitle {
      animation: hero-fade-up 500ms ease-out both;
      animation-delay: 120ms;
    }

    .hero__tagline {
      animation: hero-fade-up 450ms ease-out both;
      animation-delay: 240ms;
    }

    .hero__text > :global(.app-store-buttons) {
      animation: hero-fade-up 400ms ease-out both;
      animation-delay: 360ms;
    }
  }

  @media (max-width: 809px) {
    .hero {
      padding: 80px 0 0;
    }

    .hero__tagline {
      max-width: 100%;
    }
  }
</style>
