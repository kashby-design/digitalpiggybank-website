---
import { Image } from 'astro:assets';
import AppStoreButtons from './AppStoreButtons.astro';
import phoneImages from '../images/phone-images.png';
---

<section class="cta">
  <div class="cta__inner container">
    <div class="cta__text" data-reveal="fade-up">
      <h2>Put a Piggy Bank in Your Pocket</h2>
      <AppStoreButtons />
    </div>
    <div class="cta__image" data-reveal="fade-up">
      <Image
        src={phoneImages}
        alt="3 phones with different screens from the Digital Piggy Bank app"
        widths={[400, 600, 900]}
        sizes="(max-width: 480px) 100vw, 500px"
        format="avif"
        quality={75}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .cta {
    background: #EDF2F7;
    padding: 96px 0 0;
    overflow: hidden;
  }

  .cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  .cta__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .cta h2 {
    color: #1A202C;
    margin: 0;
    line-height: 1;
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.75rem);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .cta__image {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cta__image img {
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 809px) {
    .cta {
      padding: 56px 0 0;
    }

    .cta__inner {
      gap: 32px;
    }
  }
</style>
