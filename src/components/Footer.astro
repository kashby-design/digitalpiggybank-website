---
import AppStoreButtons from './AppStoreButtons.astro';
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__content" data-reveal="fade-up">
      <h3 class="footer__download-heading">Download the app today!</h3>
      <AppStoreButtons />

      <div class="footer__columns">
