          <a href="/blog">Blog</a>
          <a href="/blog/tags">Topics</a>
          <a href="/about">About</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms & Conditions</a>
        </nav>

        <div class="footer__social">
          <a href="https://www.facebook.com/profile.php?id=61566121137460" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
