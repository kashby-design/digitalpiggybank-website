        </div>

        <p class="footer__copyright">Digital Piggy Bank &copy; {new Date().getFullYear()}</p>
      </div>
    </div>

    <div class="footer__mascot" data-reveal="fade-in" data-stagger="1">
      <img src="/images/piggy-face-footer.svg" alt="Digital Piggy Bank pig mascot" width="200" height="200" />
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 72px 0 48px;
    background: radial-gradient(174.79% 102.86% at 10.77% 1.07%, #E1025B 0%, #FD2375 34.22%, #E51362 68.14%, #B9074A 100%);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 60px;
  }

  .footer__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__download-heading {
    color: var(--color-white);
    margin: 0;
    line-height: 1.2;
  }

  .footer__content > :global(.app-store-buttons) {
    margin-bottom: 12px;
  }

  .footer__columns {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer__nav a {
    color: var(--color-text-on-dark);
    font-size: var(--font-size-sm);
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }

  .footer__nav a:hover {
    opacity: 0.8;
  }

  .footer__social {
    display: flex;
    gap: 20px;
    margin-top: 8px;
  }

  .footer__social a {
    color: var(--color-text-on-dark);
    transition: color 0.2s ease-out, transform 0.2s ease-out;
  }

  .footer__social a:hover {
    color: #F582EF;
    transform: translateY(-2px);
  }

  .footer__copyright {
    font-size: var(--font-size-xs);
    color: var(--color-white);
    opacity: 0.8;
    margin-top: 8px;
  }

  .footer__mascot img {
    width: 220px;
    height: auto;
  }

  @media (max-width: 809px) {
    .footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__mascot {
      order: -1;
    }

    .footer__content {
      align-items: center;
    }

    .footer__nav {
      align-items: center;
    }

    .footer__social {
      justify-content: center;
    }

    .footer__mascot img {
      width: 150px;
    }
  }
</style>
