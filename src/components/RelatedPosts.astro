---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  tags: string[];
  limit?: number;
}

const { currentSlug, tags, limit = 3 } = Astro.props;

type Post = CollectionEntry<'blog'>;

const all = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.id !== currentSlug);

function score(p: Post): number {
  const overlap = (p.data.tags ?? []).filter((t) => tags.includes(t)).length;
  return overlap;
}

const ranked = all
  .map((p) => ({ post: p, s: score(p) }))
  .filter((x) => x.s > 0)
  .sort((a, b) => {
    if (b.s !== a.s) return b.s - a.s;
    return b.post.data.date.valueOf() - a.post.data.date.valueOf();
  })
  .slice(0, limit)
  .map((x) => x.post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

{ranked.length > 0 && (
  <aside class="related" aria-label="Related posts">
    <h2 class="related__heading">Related reading</h2>
    <div class="related__grid">
      {ranked.map((p) => (
        <a class="related__card" href={`/blog/${p.id}`}>
          <div class="related__image">
            <img src={p.data.image} alt={p.data.imageAlt} loading="lazy" width="300" height="180" />
          </div>
          <div class="related__body">
            <p class="related__date">{formatDate(p.data.date)}</p>
            <h3 class="related__title">{p.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </aside>
)}

<style>
  .related {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .related__heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 24px;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }

  .related__card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
    color: inherit;
  }

  .related__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .related__image img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    display: block;
  }

  .related__body {
    padding: 14px 16px 18px;
  }

  .related__date {
    font-size: 0.78rem;
    color: var(--color-text-light);
    margin: 0 0 6px;
  }

  .related__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    line-height: 1.3;
    margin: 0;
  }

  @media (max-width: 480px) {
    .related__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
